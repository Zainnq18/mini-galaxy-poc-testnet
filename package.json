{
  "name": "mini-galaxy-poc-ent",
  "version": "4.4.0",
  "description": "Production-style tokenised proxy voting portal with Reown AppKit, protected role workspaces, delegation, robust ballot signature verification, and Broadridge UI polish.",
  "private": true,
  "scripts": {
    "chain": "hardhat node",
    "frontend": "concurrently -k -n API,VITE \"node relayer/server.js\" \"vite --host 0.0.0.0 --port 5173\"",
    "relayer": "node relayer/server.js",
    "compile": "hardhat compile",
    "deploy": "hardhat run scripts/deploy.js --network localhost",
    "seed": "hardhat run scripts/seed.js --network localhost",
    "export": "hardhat run scripts/exportState.js --network localhost",
    "test": "hardhat test",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "deploy:amoy": "hardhat run scripts/deploy.js --network polygonAmoy",
    "deploy:registry:amoy": "hardhat run scripts/deployRegistry.js --network polygonAmoy",
    "check:testnet": "node scripts/checkTestnetConfig.js",
    "render:build": "npm install && npm run compile",
    "render:start": "npm run relayer"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.0.2",
    "@reown/appkit": "^1.8.20",
    "@reown/appkit-adapter-ethers": "^1.8.20",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "^2.22.17"
  }
}
